{
  "compilerOptions": {
    /* Эти настройки здесь нужны для инструментов анализа и IDE */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    
    /* Базовые настройки для распознавания путей */
    "moduleResolution": "bundler",
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true
  },
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
}